{
  "_说明": "进度条样式配置文件",
  
  "styles": {
    "_说明_styles": "预定义样式列表，可通过 --style 参数选择",
    
    "A": {
      "_说明": "半透明底层 + 浅黑色前景",
      "bg_color": "808080",
      "bg_alpha": 0.4,
      "fg_color": "333333",
      "fg_alpha": 0.7,
      "height": 50,
      "position": "bottom"
    },
    
    "RED": {
      "_说明": "灰色底层 + 红色前景（默认样式）",
