      "bg_alpha": 1.0,
      "fg_color": "FF0000",
      "fg_alpha": 1.0,
      "height": 50,
      "position": "bottom"
    },
    
    "DY": {
      "_说明": "白色底层 + 红色前景",
      "bg_color": "FFFFFF",
      "bg_alpha": 0.3,
      "fg_color": "FF0000",
      "fg_alpha": 1.0,
      "height": 50,
      "position": "bottom"
    }
  },
  
  "_说明_default_style": "默认使用的样式名称",
